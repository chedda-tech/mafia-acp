# ACP Configuration
WHITELISTED_WALLET_PRIVATE_KEY=0x...   # Dev wallet (must include 0x prefix)
AGENT_WALLET_ADDRESS=0x...             # Smart contract wallet from ACP portal
ENTITY_ID=                             # Integer from agent registration

# Database (Supabase)
DATABASE_URL=postgresql://...

# Terminal API (existing)
TERMINAL_API_URL=https://...

# API Keys
COINMARKETCAP_API_KEY=
ANTHROPIC_API_KEY=sk-ant-...

# Monitoring Config (optional, defaults shown)
LOG_LEVEL=INFO
STATUS_UPDATE_INTERVAL_MINUTES=15
STALE_DATA_THRESHOLD_SECONDS=300
MAX_SWAP_RETRIES=3
