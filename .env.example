# ACP Configuration
# Dev wallet private key (must include 0x prefix)
WHITELISTED_WALLET_PRIVATE_KEY=0x...
# Smart contract wallet from ACP portal
AGENT_WALLET_ADDRESS=0x...
# Integer from agent registration
ENTITY_ID=
# "testnet" (Base Sepolia sandbox) or "mainnet" (Base production)
ACP_NETWORK=testnet

# Mafia API (Provides /api/metrics and /api/intel-drop)
MAFIA_API_BASE_URL=https://...

# LLM (any OpenAI-compatible provider — OpenRouter, Together, Groq, etc.)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=deepseek/deepseek-chat

# Database (required for Railway/production — uses Supabase PostgreSQL for durable idempotency)
# Optional for local dev — falls back to SQLite at IDEMPOTENCY_DB_PATH if not set
DATABASE_URL=postgresql://...

# Monitoring Config (optional, defaults shown)
LOG_LEVEL=INFO
STATUS_UPDATE_INTERVAL_MINUTES=15
STALE_DATA_THRESHOLD_SECONDS=300
MAX_SWAP_RETRIES=3
DATA_REFRESH_INTERVAL_SECONDS=60
IDEMPOTENCY_DB_PATH=.state/idempotency.db
JOB_LOCK_TTL_SECONDS=300
